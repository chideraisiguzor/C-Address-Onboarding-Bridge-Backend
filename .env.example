# Soroban RPC endpoints
SOROBAN_RPC_URL=https://soroban-rpc.testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Contract address (after deployment)
BRIDGE_CONTRACT_ID=

# Fee configuration (basis points, e.g. 30 = 0.3%)
BRIDGE_FEE_BPS=30

# API authentication (comma-separated list of accepted keys)
API_KEYS=your-api-key-here

# Moonpay API
MOONPAY_API_KEY=
MOONPAY_SECRET_KEY=

# Transak API
TRANSAK_API_KEY=
TRANSAK_ENVIRONMENT=STAGING

# Generic CEX API endpoint (optional, for custom CEX integrations)
CEX_API_ENDPOINT=

# Server
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development
